# Your public domain — the proxy rejects requests from other origins.
# Leave empty to allow all origins (fine for local/private use).
# Example: https://paperview.yourdomain.com
PAPERVIEW_ORIGIN=

# Port the frontend is exposed on (default: 8080)
FRONTEND_PORT=8080

# ── OpenAI (optional) ─────────────────────────────────────────────────────────
# If set, this key is baked into the frontend build as a fallback default.
# Users can always supply their own key via the Settings panel.
# Recommended: leave empty — let users provide their own key.
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-5.4-mini
VITE_OPENAI_MODELS=gpt-5.4-nano,gpt-5.4-mini,gpt-5.4
